# Proximity Coaching — Netlify Security Headers
# Applied to all pages unless overridden below

/*
  # Prevent clickjacking
  X-Frame-Options: DENY
  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff
  # Limit referrer info (keeps auth tokens from leaking)
  Referrer-Policy: strict-origin-when-cross-origin
  # Block legacy XSS filter bypass attempts
  X-XSS-Protection: 1; mode=block
  # Disable browser features not needed
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  # Enforce HTTPS for 1 year (includeSubDomains)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # Content Security Policy
  # script-src: allow our two CDNs + inline (required — pages use inline <script> blocks)
  # connect-src: Supabase project only
  # frame-ancestors: redundant with X-Frame-Options but defense-in-depth
  Content-Security-Policy: default-src 'none'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline'; connect-src https://osywbzzvsfjdvjhjalju.supabase.co; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';

# Auth callback page — never cache (contains live session logic)
/auth-callback.html
  Cache-Control: no-store, no-cache, must-revalidate

# Coach pages — no caching (session-gated content)
/proxi-he.html
